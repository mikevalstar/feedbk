{
  "name": "design-feedback-monorepo",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter \"./packages/*\" run build && pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "db:generate": "pnpm --filter @repo/backend run db:generate",
    "db:migrate": "pnpm --filter @repo/backend run db:migrate"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
